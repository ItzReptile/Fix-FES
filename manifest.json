{
  "manifest_version": 3,
  "name": "Fix FES",
  "version": "1.0",
  "host_permissions": [
    "https://slack.com/*",
    "https://app.fesinstitute.com/*",
    "https://beta.fesinstitute.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.fesinstitute.com/dashboard/fes/admin/tickets*",
        "https://beta.fesinstitute.com/dashboard/fes/program*"
      ],
      "js": ["secrets.js", "content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://app.fesinstitute.com/*",
        "https://beta.fesinstitute.com/*"
      ],
      "js": ["fes-ws-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://app.fesinstitute.com/dashboard/fes/admin/tickets*",
        "https://beta.fesinstitute.com/dashboard/fes/program*"
      ],
      "js": ["slack-bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}